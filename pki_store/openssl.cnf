[ ca ]
default_ca = socratesca

[ socratesca ]
# Using forward slashes is safer for OpenSSL on Windows
dir             = C:/testCertificateAuth
certs           = $dir/certs
new_certs_dir   = $dir/certs
database        = $dir/index.txt
serial          = $dir/serial
private_key     = $dir/private/ca_private_key.pem
certificate     = $dir/ca_certificate.pem

default_md      = sha256
default_days    = 3652
policy          = testca_policy
# Extensions used when the CA signs a certificate
x509_extensions = mtls_extensions 

[ testca_policy ]
commonName              = supplied
stateOrProvinceName     = optional
countryName             = optional
emailAddress            = optional
organizationName        = optional
organizationalUnitName  = optional

[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = yes
distinguished_name  = root_ca_distinguished_name
# Extensions used when creating a CSR
req_extensions      = v3_req 

[ root_ca_distinguished_name ]
commonName                  = Common Name (eg, your name or server hostname)
commonName_default          = SOCRATES.INC
stateOrProvinceName         = State or Province Name
countryName                 = Country Name (2 letter code)
countryName_default         = US

[ v3_req ]
# This is what goes into the Certificate Signing Request (CSR)
basicConstraints = CA:FALSE
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth

[ mtls_extensions ]
# This is what the CA adds to the final .pem/.crt file
basicConstraints       = CA:FALSE
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth, clientAuth
nsComment              = "Windows mTLS Certificate"

[ root_ca_extensions ]
# Only used for generating the Root CA itself
basicConstraints       = critical, CA:true
keyUsage               = critical, keyCertSign, cRLSign
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer